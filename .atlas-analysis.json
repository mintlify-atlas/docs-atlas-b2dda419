  "keyFeatures": [
    "Complete applicant tracking system with job posting and candidate management",
    "Customizable recruitment pipelines with multiple stages and drag-and-drop interface",
    "Technical assessment creation and execution with automatic grading",
    "Template-based offer letter generation with dynamic variables",
    "Real-time collaboration with team chat and Socket.IO integration",
    "Email automation using Resend for candidate communications",
    "Resume and document storage with AWS S3/R2 integration",
    "Role-based access control for hiring team members",
    "Custom application form questions per job posting",
    "Department and user management for recruitment teams"
  ],
  "publicApiSurface": [
    "POST /api/jobs - Create job posting",
    "GET /api/jobs - List all jobs",
    "GET /api/jobs/:id - Get job details",
    "POST /api/candidates/apply - Submit job application",
    "GET /api/candidates - List candidates",
    "PUT /api/candidates/:id/stage - Move candidate through pipeline",
    "POST /api/assessments - Create technical assessment",
    "POST /api/assessment-execution/invite - Invite candidate to assessment",
    "POST /api/assessment-execution/start - Start assessment attempt",
    "POST /api/assessment-execution/submit - Submit assessment answer",
    "POST /api/offers - Generate offer letter",
    "PUT /api/offers/:id - Update offer status",
    "GET /api/templates - List email/document templates",
    "POST /api/company/departments - Create department",
    "GET /api/users - List team members",
    "POST /api/chat/job/:jobId - Send team message",
    "POST /api/upload/resume - Upload candidate resume",
    "GET /api/pipelines/:jobId - Get job pipeline stages"
  ]
}
